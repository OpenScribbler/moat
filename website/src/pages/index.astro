---
// MOAT landing page
// Custom page — does not use Starlight's layout.
// Theme syncs with Starlight docs via localStorage key 'starlight-theme'.
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MOAT — AI agent content, verified at install.</title>
  <meta name="description" content="Model for Origin Attestation and Trust — an open protocol for provenance and integrity of AI agent content." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <script is:inline>
    (function () {
      try {
        var stored = localStorage.getItem('starlight-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = stored || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      } catch (e) {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>

  <style>
    /* ─── Flexoki palette · light ───────────────────────────────── */
    html[data-theme="light"] {
      --paper:     #fffcf0;
      --base-50:   #f2f0e5;
      --base-100:  #e6e4d9;
      --base-200:  #cecdc3;
      --base-300:  #b7b5ac;
      --base-500:  #6f6e69;
      --base-600:  #575653;
      --base-700:  #403e3c;
      --base-800:  #282726;
      --base-900:  #100f0f;

      --bg:            var(--paper);
      --bg-soft:       var(--base-50);
      --bg-card:       #ffffff;
      --bg-elev:       #ffffff;

      --ink:           var(--base-900);
      --ink-soft:      var(--base-700);
      --ink-muted:     var(--base-500);
      --ink-faint:     var(--base-300);

      --border:        var(--base-100);
      --border-strong: var(--base-200);

      --signed:        #66800b;
      --signed-soft:   rgba(102, 128, 11, 0.10);
      --signed-glow:   rgba(102, 128, 11, 0.32);
      --attested:      #205ea6;
      --attested-soft: rgba(32, 94, 166, 0.10);
      --attested-glow: rgba(32, 94, 166, 0.32);
      --verified:      #24837b;
      --verified-soft: rgba(36, 131, 123, 0.10);
      --verified-glow: rgba(36, 131, 123, 0.32);
      --rekor:         #ad8301;
      --rekor-soft:    rgba(173, 131, 1, 0.10);
      --rekor-glow:    rgba(173, 131, 1, 0.32);

      --diagram-bg:      #ffffff;
      --diagram-grid:    #d4d2c8;
      --node-fill:       #ffffff;
      --node-stroke-dim: var(--base-200);
      --node-text-dim:   var(--base-500);

      --shadow-card: 0 1px 2px rgba(16,15,15,0.04), 0 8px 28px rgba(16,15,15,0.06);
      --shadow-elev: 0 12px 40px -8px rgba(16,15,15,0.18);
    }

    /* ─── Flexoki palette · dark ────────────────────────────────── */
    html[data-theme="dark"] {
      --paper:     #fffcf0;
      --base-300:  #b7b5ac;
      --base-500:  #6f6e69;
      --base-700:  #403e3c;
      --base-800:  #282726;
      --base-850:  #1c1b1a;
      --base-900:  #100f0f;

      --bg:            var(--base-900);
      --bg-soft:       var(--base-850);
      --bg-card:       var(--base-800);
      --bg-elev:       #2e2c2a;

      --ink:           var(--paper);
      --ink-soft:      var(--base-300);
      --ink-muted:     var(--base-500);
      --ink-faint:     var(--base-700);

      --border:        var(--base-800);
      --border-strong: var(--base-700);

      --signed:        #879a39;
      --signed-soft:   rgba(135, 154, 57, 0.16);
      --signed-glow:   rgba(135, 154, 57, 0.45);
      --attested:      #4385be;
      --attested-soft: rgba(67, 133, 190, 0.16);
      --attested-glow: rgba(67, 133, 190, 0.45);
      --verified:      #3aa99f;
      --verified-soft: rgba(58, 169, 159, 0.16);
      --verified-glow: rgba(58, 169, 159, 0.45);
      --rekor:         #d0a215;
      --rekor-soft:    rgba(208, 162, 21, 0.16);
      --rekor-glow:    rgba(208, 162, 21, 0.45);

      --diagram-bg:      var(--base-850);
      --diagram-grid:    #2a2826;
      --node-fill:       var(--base-800);
      --node-stroke-dim: var(--base-700);
      --node-text-dim:   var(--base-500);

      --shadow-card: 0 1px 2px rgba(0,0,0,0.4), 0 8px 28px rgba(0,0,0,0.45);
      --shadow-elev: 0 24px 60px -12px rgba(0,0,0,0.6);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--ink);
      line-height: 1.55;
      -webkit-font-smoothing: antialiased;
      scroll-behavior: smooth;
      transition: background-color 0.25s ease, color 0.25s ease;
    }

    a { color: var(--verified); text-decoration: none; }
    a:hover { color: var(--ink); }

    code {
      font-family: 'JetBrains Mono', ui-monospace, monospace;
      font-size: 0.9em;
      background: var(--bg-soft);
      padding: 0.1em 0.4em;
      border-radius: 3px;
      color: var(--verified);
      border: 1px solid var(--border);
    }

    .container { max-width: 1180px; margin: 0 auto; padding: 0 2rem; }

    /* ─── Site header ─── */
    .site-header {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 1rem 0;
    }
    .site-header .container {
      display: flex; align-items: center; gap: 2rem;
    }
    .logo {
      display: inline-flex; align-items: center; gap: 0.55rem;
      font-weight: 700; font-size: 1rem; letter-spacing: 0.04em;
      color: var(--ink);
    }
    .logo-mark {
      width: 1.5rem; height: 1.5rem;
      background: linear-gradient(135deg, var(--verified), var(--attested));
      border-radius: 50% 50% 4px 4px;
      box-shadow: 0 0 14px var(--verified-glow);
    }
    .site-header nav { display: flex; gap: 1.5rem; flex: 1; }
    .site-header nav a {
      font-size: 0.9rem; color: var(--ink-muted); font-weight: 500;
    }
    .site-header nav a:hover { color: var(--ink); }
    .header-tools { display: flex; align-items: center; gap: 0.6rem; }
    .theme-toggle {
      display: inline-flex; align-items: center; justify-content: center;
      width: 2rem; height: 2rem;
      background: transparent; border: 1px solid var(--border-strong);
      border-radius: 6px; color: var(--ink-soft);
      cursor: pointer; transition: all 0.18s ease;
    }
    .theme-toggle:hover { color: var(--ink); border-color: var(--ink-muted); }
    .theme-toggle svg { width: 16px; height: 16px; }
    html[data-theme="dark"]  .theme-toggle .icon-moon { display: none; }
    html[data-theme="light"] .theme-toggle .icon-sun  { display: none; }

    .header-cta {
      padding: 0.5rem 0.95rem;
      background: var(--ink); color: var(--bg) !important;
      border-radius: 6px; font-size: 0.85rem; font-weight: 600;
    }
    .header-cta:hover { background: var(--ink-soft); color: var(--bg) !important; }

    /* ─── Hero ─── */
    .hero {
      padding: 4rem 0 4rem;
      text-align: center;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute;
      inset: 0; pointer-events: none; z-index: 0;
      background: radial-gradient(ellipse 60% 40% at 50% 30%, var(--verified-soft), transparent 60%);
    }
    .hero .container { position: relative; z-index: 1; }

    .spec-tag {
      display: inline-flex; align-items: center; gap: 0.55rem;
      padding: 0.35rem 0.9rem;
      background: var(--verified-soft);
      border: 1px solid color-mix(in srgb, var(--verified) 35%, transparent);
      border-radius: 999px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.75rem; color: var(--verified);
      letter-spacing: 0.04em;
      margin-bottom: 1.75rem;
    }
    .spec-tag::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--verified); box-shadow: 0 0 8px var(--verified-glow);
    }

    h1 {
      font-size: clamp(2.4rem, 5vw, 4rem);
      font-weight: 700; line-height: 1.05;
      letter-spacing: -0.035em;
      margin: 0 auto 1.4rem;
      max-width: 22ch;
      color: var(--ink);
    }
    h1 .accent { color: var(--verified); }
    .tagline {
      font-size: 1.15rem; color: var(--ink-soft);
      max-width: 36rem; line-height: 1.55;
      margin: 0 auto 0.85rem;
    }
    .subhead {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.85rem; color: var(--ink-muted);
      margin-bottom: 2rem;
    }
    .hero-ctas { display: flex; gap: 0.7rem; justify-content: center; flex-wrap: wrap; }
    .cta-primary, .cta-secondary {
      padding: 0.78rem 1.4rem; border-radius: 8px;
      font-size: 0.92rem; font-weight: 600;
      transition: all 0.18s ease;
      display: inline-flex; align-items: center; gap: 0.4rem;
    }
    .cta-primary {
      background: var(--ink); color: var(--bg) !important;
    }
    .cta-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px -6px var(--verified-glow);
    }
    .cta-secondary {
      background: var(--bg-card); color: var(--ink) !important;
      border: 1px solid var(--border-strong);
    }
    .cta-secondary:hover { border-color: var(--verified); }

    /* ─── Section chrome ─── */
    .section-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.14em; color: var(--ink-muted);
      margin-bottom: 1rem;
    }

    /* ─── How section ─── */
    .how-section {
      padding-top: 5rem;
      background:
        radial-gradient(circle at 1px 1px, var(--diagram-grid) 1px, transparent 0);
      background-size: 24px 24px;
      background-color: var(--bg);
    }

    .how-header {
      padding-bottom: 1.5rem;
    }
    .how-header h2 {
      font-size: clamp(1.6rem, 2.5vw, 2.1rem);
      font-weight: 700; line-height: 1.15;
      letter-spacing: -0.015em;
      margin-bottom: 0.6rem;
    }
    .how-header p {
      font-size: 0.975rem; color: var(--ink-soft);
      line-height: 1.6;
    }

    /* ─── Scrollytelling: 2-column ─── */
    .scrolly-wrap {
      display: grid;
      grid-template-columns: 60fr 40fr;
      gap: 4rem;
      align-items: start;
    }

    /* Left: sticky diagram */
    .scrolly-fig {
      position: sticky;
      top: 5.5rem;
      align-self: start;
      padding: 3rem 0;
    }

    .diagram-frame {
      background: var(--diagram-bg);
      border: 1px solid var(--border-strong);
      border-radius: 14px;
      padding: 1.75rem;
      box-shadow: var(--shadow-elev);
      position: relative;
    }

    .fig-label {
      position: absolute;
      top: -10px; left: 1.75rem;
      background: var(--bg);
      padding: 0 0.6rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem; color: var(--ink-muted);
      letter-spacing: 0.07em;
    }

    .diagram-svg {
      width: 100%; height: auto; display: block;
    }

    /* ─── SVG node states ─── */
    .node {
      transition: filter 0.2s ease, opacity 0.2s ease;
      opacity: 0.22;
    }
    .node.active { opacity: 1; }
    .node.publisher.active { filter: drop-shadow(0 0 14px var(--signed-glow)); }
    .node.registry.active  { filter: drop-shadow(0 0 14px var(--attested-glow)); }
    .node.consumer.active  { filter: drop-shadow(0 0 14px var(--verified-glow)); }
    .node.rekor.active     { filter: drop-shadow(0 0 10px var(--rekor-glow)); }

    .node-rect {
      transition: stroke 0.2s ease;
    }
    .node.publisher .node-rect { stroke: var(--node-stroke-dim); }
    .node.registry  .node-rect { stroke: var(--node-stroke-dim); }
    .node.consumer  .node-rect { stroke: var(--node-stroke-dim); }
    .node.rekor     .node-rect { stroke: var(--node-stroke-dim); }

    .node.publisher.active .node-rect { stroke: var(--signed); }
    .node.registry.active  .node-rect { stroke: var(--attested); }
    .node.consumer.active  .node-rect { stroke: var(--verified); }
    .node.rekor.active     .node-rect { stroke: var(--rekor); }

    /* Flow lines: drawn via dashoffset */
    .flow-line {
      stroke-dasharray: 200;
      stroke-dashoffset: 200;
      transition: stroke-dashoffset 0.2s ease;
    }
    .flow-line.active { stroke-dashoffset: 0; }

    /* Badges */
    .badge-pulse {
      opacity: 0;
      transform-origin: center;
      transform: scale(0.82);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .badge-pulse.active { opacity: 1; transform: scale(1); }

    /* ─── Right: text steps ─── */
    .top-sentinel {
      height: 30vh;
    }

    .scroll-step {
      padding: 22vh 0 22vh 2.25rem;
      position: relative;
      opacity: 0.3;
      transition: opacity 0.45s ease;
    }
    .scroll-step:first-of-type { padding-top: 8vh; }
    .scroll-step:last-of-type  { padding-bottom: 38vh; }

    .scroll-step::before {
      content: '';
      position: absolute;
      left: 0;
      top: 22vh; bottom: 22vh;
      width: 2px;
      background: var(--border-strong);
      border-radius: 2px;
      transition: background 0.4s ease;
    }
    .scroll-step:first-of-type::before { top: 8vh; }
    .scroll-step:last-of-type::before  { bottom: 38vh; }

    .scroll-step.active { opacity: 1; }
    .signed-step.active::before   { background: var(--signed); }
    .attested-step.active::before { background: var(--attested); }
    .verified-step.active::before { background: var(--verified); }

    .step-num {
      display: block;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.14em;
      color: var(--ink-faint);
      margin-bottom: 0.65rem;
      transition: color 0.4s ease;
    }
    .signed-step.active   .step-num { color: var(--signed); }
    .attested-step.active .step-num { color: var(--attested); }
    .verified-step.active .step-num { color: var(--verified); }

    .scroll-step h3 {
      font-size: 1.65rem; font-weight: 700;
      line-height: 1.15; letter-spacing: -0.015em;
      margin-bottom: 0.7rem;
    }
    .scroll-step p {
      font-size: 1rem; color: var(--ink-soft);
      line-height: 1.7; max-width: 28rem;
    }
    .scroll-step p + p { margin-top: 0.75rem; }

    /* ─── "What MOAT verifies" section ─── */
    .verify-section {
      padding: 6rem 0;
      border-top: 1px solid var(--border);
      margin-top: 0;
    }
    .verify-section .section-eyebrow { margin-bottom: 0.75rem; }
    .verify-section h2 {
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      font-weight: 700; margin-bottom: 3rem;
      letter-spacing: -0.015em;
    }
    .verify-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.5rem;
    }
    .verify-card {
      background: var(--bg-soft);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
    }
    .verify-card .card-icon {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.12em;
      color: var(--ink-muted);
      margin-bottom: 0.65rem;
    }
    .verify-card h4 {
      font-size: 0.975rem; font-weight: 600;
      margin-bottom: 0.4rem;
    }
    .verify-card p {
      font-size: 0.875rem; color: var(--ink-muted);
      line-height: 1.6;
    }

    /* ─── First adopter section ─── */
    .adopter-section {
      padding: 5rem 0;
      border-top: 1px solid var(--border);
    }
    .adopter-section .section-eyebrow { margin-bottom: 0.75rem; }
    .adopter-section h2 {
      font-size: clamp(1.5rem, 2.5vw, 2rem);
      font-weight: 700; letter-spacing: -0.015em;
      margin-bottom: 0.65rem;
    }
    .adopter-section > .container > p {
      font-size: 1rem; color: var(--ink-soft);
      max-width: 36rem; line-height: 1.65;
      margin-bottom: 2.5rem;
    }
    .adopter-facts {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .adopter-fact {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-left: 3px solid var(--verified);
      border-radius: 10px;
      padding: 1.5rem 1.75rem;
    }
    .adopter-fact.registry { border-left-color: var(--attested); }
    .adopter-fact .fact-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem; font-weight: 500;
      letter-spacing: 0.12em;
      color: var(--verified);
      margin-bottom: 0.6rem;
    }
    .adopter-fact.registry .fact-label { color: var(--attested); }
    .adopter-fact h4 {
      font-size: 1.05rem; font-weight: 600;
      margin-bottom: 0.45rem;
    }
    .adopter-fact p {
      font-size: 0.9rem; color: var(--ink-muted);
      line-height: 1.6;
    }
    .fact-link {
      display: inline-block;
      margin-top: 1rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: var(--verified);
      letter-spacing: 0.02em;
    }
    .fact-link:hover { color: var(--ink); }
    .fact-link.registry { color: var(--attested); }

    /* ─── Status card ─── */
    .status-section { padding: 5rem 0; border-top: 1px solid var(--border); }
    .status-card {
      background:
        linear-gradient(135deg, var(--verified-soft), var(--signed-soft)),
        var(--bg-card);
      border: 1px solid var(--border-strong);
      border-radius: 14px;
      padding: 3rem;
      display: grid; grid-template-columns: 1fr auto;
      gap: 3rem; align-items: center;
      margin-top: 1rem;
    }
    .status-eyebrow {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem; color: var(--signed);
      letter-spacing: 0.08em; text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .status-eyebrow::before {
      content: ''; width: 8px; height: 8px; border-radius: 50%;
      background: var(--signed); box-shadow: 0 0 8px var(--signed-glow);
    }
    .status-card h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); margin-bottom: 0.85rem; max-width: 18ch; }
    .status-card p  { color: var(--ink-soft); font-size: 1rem; line-height: 1.6; max-width: 32rem; }
    .status-ctas    { display: flex; flex-direction: column; gap: 0.65rem; min-width: max-content; }

    /* ─── Footer ─── */
    .site-footer {
      border-top: 1px solid var(--border);
      padding: 2rem 0;
    }
    .site-footer .container {
      display: flex; align-items: center; justify-content: space-between;
      gap: 1rem; flex-wrap: wrap;
    }
    .footer-left {
      font-size: 0.85rem; color: var(--ink-muted);
    }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a {
      font-size: 0.85rem; color: var(--ink-muted);
    }
    .footer-links a:hover { color: var(--ink); }

    /* ─── Responsive ─── */
    @media (max-width: 960px) {
      .scrolly-wrap {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .scrolly-fig {
        position: static;
        padding: 2rem 0 1rem;
      }
      /* All nodes and lines visible on mobile */
      .node       { opacity: 1 !important; filter: none !important; }
      .flow-line  { stroke-dashoffset: 0 !important; }
      .badge-pulse { opacity: 1 !important; transform: scale(1) !important; }
      .node.publisher .node-rect { stroke: var(--signed) !important; }
      .node.registry  .node-rect { stroke: var(--attested) !important; }
      .node.consumer  .node-rect { stroke: var(--verified) !important; }
      .node.rekor     .node-rect { stroke: var(--rekor) !important; }

      .scroll-step {
        padding: 2rem 0 2rem 1.5rem;
        opacity: 1 !important;
      }
      .scroll-step::before { display: none; }
      .top-sentinel { display: none; }

      .site-header nav { display: none; }

      .status-card {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      .status-ctas { flex-direction: row; flex-wrap: wrap; }
    }

    @media (max-width: 600px) {
      h1 { font-size: 2rem; }
      .hero { padding: 2.5rem 0 2.5rem; }
    }
  </style>
</head>

<body>

  <!-- Header -->
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">
        <span class="logo-mark" aria-hidden="true"></span>MOAT
      </a>
      <nav>
        <a href="#how">Trust flow</a>
        <a href="/overview/what-is-moat">Docs</a>
        <a href="/spec/core">Spec</a>
        <a href="https://github.com/OpenScribbler/moat" target="_blank" rel="noopener">GitHub</a>
      </nav>
      <div class="header-tools">
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle color scheme">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4"/>
